FROM python:3.11-slim

# Minimal image for testing the ETL pipeline only (no PhysicsNeMo, no PyTorch).
# Installs physicsnemo-curator with --no-deps to skip vtk/pyvista/lasso-python.

ARG EXTRA_CA_CERT_B64=""
ARG PIP_TRUSTED_HOST_FLAGS=""
ARG HTTP_PROXY
ARG HTTPS_PROXY
ARG NO_PROXY

ENV DEBIAN_FRONTEND=noninteractive \
    HTTP_PROXY=${HTTP_PROXY} \
    HTTPS_PROXY=${HTTPS_PROXY} \
    NO_PROXY=${NO_PROXY} \
    http_proxy=${HTTP_PROXY} \
    https_proxy=${HTTPS_PROXY} \
    no_proxy=${NO_PROXY} \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    openssl \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
COPY physicsnemo-curator /workspace/physicsnemo-curator

# Inject org CA certificates from the named build context "certs".
COPY --from=certs . /tmp/certs/
RUN set -eux; \
    if [ -n "${EXTRA_CA_CERT_B64}" ]; then \
        echo "${EXTRA_CA_CERT_B64}" | base64 -d > /tmp/certs/extra-ca.pem; \
    fi; \
    mkdir -p /usr/local/share/ca-certificates/custom; \
    found=0; \
    idx=0; \
    for cert_file in /tmp/certs/*; do \
        [ -e "${cert_file}" ] || continue; \
        case "${cert_file}" in \
            *.pem|*.crt|*.cer) \
                if ! openssl x509 -in "${cert_file}" -noout >/dev/null 2>&1; then \
                    echo "WARN: ${cert_file} is not a valid X.509 certificate; skipping." >&2; \
                    continue; \
                fi; \
                if ! openssl x509 -in "${cert_file}" -noout -text | grep -q "CA:TRUE"; then \
                    echo "WARN: ${cert_file} is not a CA certificate (CA:TRUE missing); skipping." >&2; \
                    continue; \
                fi; \
                idx=$((idx+1)); \
                cp "${cert_file}" "/usr/local/share/ca-certificates/custom/custom-${idx}.crt"; \
                found=1 ;; \
        esac; \
    done; \
    if [ "${found}" -eq 0 ]; then \
        echo "No custom CA files found under /tmp/certs (supported: .pem/.crt/.cer)."; \
    fi; \
    update-ca-certificates; \
    cp /etc/ssl/certs/ca-certificates.crt /etc/ssl/certs/ca-bundle.pem; \
    rm -rf /tmp/certs /usr/local/share/ca-certificates/custom

ENV SSL_CERT_FILE=/etc/ssl/certs/ca-bundle.pem \
    REQUESTS_CA_BUNDLE=/etc/ssl/certs/ca-bundle.pem \
    PIP_CERT=/etc/ssl/certs/ca-bundle.pem

# ETL dependencies only — no PhysicsNeMo, no PyTorch, no vtk/pyvista.
# physicsnemo-curator is installed with --no-deps to skip its heavy optional
# deps (vtk, pyvista, lasso-python) that the ETL base classes don't use.
RUN set -eux; \
    if ! pip install --no-cache-dir \
        --cert /etc/ssl/certs/ca-bundle.pem \
        ${PIP_TRUSTED_HOST_FLAGS} \
        "numpy>=1.26.4" \
        "scipy" \
        "netCDF4" \
        "zarr>=3.1.2" \
        "numcodecs>=0.13.1" \
        "hydra-core>=1.3" \
        "omegaconf>=2.3" \
        "tqdm>=4.67.1"; then \
        pip install --no-cache-dir \
        --cert /etc/ssl/certs/ca-bundle.pem \
        --trusted-host pypi.org \
        --trusted-host pypi.python.org \
        --trusted-host files.pythonhosted.org \
        "numpy>=1.26.4" \
        "scipy" \
        "netCDF4" \
        "zarr>=3.1.2" \
        "numcodecs>=0.13.1" \
        "hydra-core>=1.3" \
        "omegaconf>=2.3" \
        "tqdm>=4.67.1"; \
    fi; \
    if ! pip install --no-cache-dir \
        --cert /etc/ssl/certs/ca-bundle.pem \
        ${PIP_TRUSTED_HOST_FLAGS} \
        --no-deps \
        -e /workspace/physicsnemo-curator; then \
        pip install --no-cache-dir \
        --cert /etc/ssl/certs/ca-bundle.pem \
        --trusted-host pypi.org \
        --trusted-host pypi.python.org \
        --trusted-host files.pythonhosted.org \
        --no-deps \
        -e /workspace/physicsnemo-curator; \
    fi

CMD ["bash"]
